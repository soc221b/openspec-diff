{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/core/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/target/core"],
      "options": {
        "cwd": "packages/core",
        "command": "cargo build --target-dir ../../dist/target/core"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/core",
        "command": "cargo fmt --check"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/target/core"],
      "options": {
        "cwd": "packages/core",
        "parallel": false,
        "commands": [
          "npm install -g @fission-ai/openspec@latest",
          "cargo build --target-dir ../../dist/target/core",
          "node ../../run-test.ts ./tests"
        ]
      }
    }
  }
}
