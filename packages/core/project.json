{
  "name": "core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/core/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/target/core"],
      "options": {
        "cwd": "packages/core",
        "command": "cargo build --target-dir ../../dist/target/core"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/core",
        "command": "cargo fmt --check"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/target/core"],
      "options": {
        "cwd": "packages/core",
        "command": "if ! command -v openspec >/dev/null 2>&1; then npm install -g @fission-ai/openspec@latest; fi && cargo build --target-dir ../../dist/target/core && set -e && for fixture_dir in ./tests/*; do [ -d \"$fixture_dir\" ] || continue; ./tests/run-fixture-test.sh \"$fixture_dir\"; done"
      }
    }
  }
}
