{
  "name": "openspec-diff",
  "publisher": "openspec-diff",
  "version": "1.0.0",
  "displayName": "OpenSpec Diff",
  "description": "Minimal VSCode extension scaffold for openspec-diff.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/soc221b/openspec-diff",
    "directory": "packages/vscode-extension"
  },
  "main": "./dist/extension.js",
  "type": "module",
  "engines": {
    "vscode": "^1.110.0"
  },
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "openspecDiff.openDiff",
        "title": "OpenSpec Diff"
      }
    ],
    "configuration": {
      "title": "OpenSpec Diff",
      "properties": {
        "openspecDiff.openspecBin": {
          "type": "string",
          "default": "openspec",
          "description": "Path to the openspec binary used to preprocess delta specs."
        },
        "openspecDiff.difftoolBin": {
          "type": "string",
          "default": "",
          "description": "Path to the openspec-difftool binary. Leave empty to use the bundled binary."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc --noEmit && node ./scripts/build.mjs",
    "format": "prettier --check .",
    "test": "node --experimental-strip-types --test ./test/**/*.test.ts"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
