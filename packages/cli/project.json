{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/cli",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/bin"],
      "options": {
        "cwd": "packages/cli",
        "command": "go build -o ./bin/openspec-diff ./cmd/openspec-diff"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cli",
        "command": "output=$(gofmt -l .) && [ -z \"$output\" ] || { printf '%s\\n' \"$output\"; exit 1; }"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cli",
        "command": "go build -o ./bin/openspec-diff ./cmd/openspec-diff && set -e && for test_script in ./tests/*/test.sh; do \"$test_script\"; done"
      }
    }
  }
}
